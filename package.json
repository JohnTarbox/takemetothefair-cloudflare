{
  "name": "takemetothefair-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "mcp-server",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:preview": "npm run pages:build && wrangler pages dev .vercel/output/static",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply takemetothefair-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply takemetothefair-db --remote",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:backup": "bash scripts/db-backup.sh prod",
    "db:backup:local": "bash scripts/db-backup.sh local",
    "db:restore": "bash scripts/db-restore.sh",
    "db:restore:prod": "bash scripts/db-restore.sh",
    "db:backups": "bash scripts/db-list-backups.sh",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "pretest:e2e": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "PLAYWRIGHT_BASE_URL=https://meetmeatthefair.com playwright test e2e/smoke.spec.ts --project=chromium",
    "test:sweep": "npx tsx scripts/fairground-sweep.ts",
    "gvalidate": "npx tsx gvalidate/index.ts",
    "gvalidate:all": "npx tsx gvalidate/index.ts --no-fail-fast",
    "gvalidate:vendors": "npx tsx gvalidate/index.ts --type=vendor",
    "gvalidate:events": "npx tsx gvalidate/index.ts --type=event",
    "gvalidate:venues": "npx tsx gvalidate/index.ts --type=venue",
    "gvalidate:quick": "npx tsx gvalidate/index.ts --limit=3",
    "gvalidate:urls": "npx tsx gvalidate/index.ts --urls-only",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.4",
    "@hookform/resolvers": "^5.2.2",
    "@johntarbox/calendar-grid": "^0.1.0",
    "@next/third-parties": "^15.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.38.3",
    "jose": "^6.2.2",
    "lucide-react": "^0.563.0",
    "next": "^15.1.0",
    "next-auth": "^5.0.0-beta.30",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "rehype-external-links": "^3.0.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "slugify": "^1.6.6",
    "tailwind-merge": "^3.4.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20241230.0",
    "@playwright/test": "^1.40.0",
    "@testing-library/react": "^14.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.30.1",
    "eslint": "^8",
    "eslint-config-next": "^15.1.0",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.9",
    "wrangler": "^4.60.0"
  }
}
