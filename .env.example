# Database
DATABASE_URL="postgresql://takemetothefair:takemetothefair_dev@localhost:5432/takemetothefair"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"
AUTH_SECRET="your-secret-key-change-in-production"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Meet Me at the Fair"

# Analytics (optional)
# Both NEXT_PUBLIC_* vars are inlined at build time by Next.js — they MUST be
# set in the GitHub Actions deploy workflow env (not just locally), otherwise
# the rendered HTML will silently omit the tracking snippets. See
# .github/workflows/deploy.yml deploy-pages job.
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_CF_BEACON_TOKEN=""

# Cloudflare Turnstile Bot Protection
# Get keys from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Google Analytics 4 server-side reporting (powers /admin/analytics)
# Setup:
#   1. Create a service account in Google Cloud Console and download its JSON key.
#   2. Enable the "Google Analytics Data API" on that GCP project.
#   3. In GA4 -> Admin -> Property Access Management, add the service account
#      email with the "Viewer" role on the property you want to read.
# The private key is multi-line PEM. For .dev.vars / single-line stores,
# escape real newlines as \n; the app converts them back at runtime.
GA4_PROPERTY_ID=""
GA4_SA_CLIENT_EMAIL=""
GA4_SA_PRIVATE_KEY=""

# Claude read-only Bearer token (powers programmatic GET access to /admin/*).
# Set via: wrangler pages secret put CLAUDE_READONLY_TOKEN --project-name=takemetothefair
# Generate with: openssl rand -hex 16
# Read-only enforced at src/middleware.ts (method gate) + src/lib/api-auth.ts.
CLAUDE_READONLY_TOKEN=""
