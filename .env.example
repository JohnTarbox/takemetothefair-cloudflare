# Database
DATABASE_URL="postgresql://takemetothefair:takemetothefair_dev@localhost:5432/takemetothefair"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"
AUTH_SECRET="your-secret-key-change-in-production"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Meet Me at the Fair"

# Analytics (optional)
NEXT_PUBLIC_GA_ID=""

# Cloudflare Turnstile Bot Protection
# Get keys from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Google Analytics 4 server-side reporting (powers /admin/analytics)
# Setup:
#   1. Create a service account in Google Cloud Console and download its JSON key.
#   2. Enable the "Google Analytics Data API" on that GCP project.
#   3. In GA4 -> Admin -> Property Access Management, add the service account
#      email with the "Viewer" role on the property you want to read.
# The private key is multi-line PEM. For .dev.vars / single-line stores,
# escape real newlines as \n; the app converts them back at runtime.
GA4_PROPERTY_ID=""
GA4_SA_CLIENT_EMAIL=""
GA4_SA_PRIVATE_KEY=""
