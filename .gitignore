# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/mcp-server/node_modules
/apex-worker/node_modules
/packages/*/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# claude code local state (user-specific permissions + runtime lock)
/.claude/settings.local.json
/.claude/scheduled_tasks.lock

# testing
/coverage
/playwright-report/
/test-results/
/.auth/

# next.js
/.next/
/mcp-server/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Cloudflare
.wrangler/
.dev.vars

# Database backups
/backups/*.sql

# gvalidate output
gvalidate-results/

# Analyst-reply drafts staged at repo root before copying to Downloads.
# Session-internal artifacts (private operator decisions, not committed code).
ANALYST_REPLY_*.md

# Local-only design discussions held outside committed docs/.
docs/repo-privacy-tradeoff.md
.open-next/
